# WPOS Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration (public keys - safe for client)
VITE_SUPABASE_URL="https://nsbmrtohkdttsufxwzdi.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="nsbmrtohkdttsufxwzdi"

# Server-side only
SUPABASE_URL="https://nsbmrtohkdttsufxwzdi.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
SUPABASE_PROJECT_ID="nsbmrtohkdttsufxwzdi"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Runtime
NODE_ENV="development"

# Optional: OpenAI API key for the Insights Assistant's deeper free-form Q&A.
# When unset, the built-in deterministic analysis engine is used instead.
# All structured insights / scoring / predictions elsewhere in WPOS do NOT
# depend on this key.
VITE_OPENAI_API_KEY=""
